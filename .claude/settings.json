{
  "permissions": {
    "allow": [
      "mcp__abap-adt__GetTransport",
      "mcp__abap-adt__RunQuery",
      "mcp__abap-adt__GetConnectionInfo",
      "mcp__abap-adt__GetFeatures",
      "mcp__abap-adt__ListTransports",
      "mcp__abap-adt__CallRFC",
      "mcp__abap-adt__GetTableContents",
      "mcp__abap-adt__SearchObject",
      "mcp__abap-adt__GetSource",
      "mcp__abap-adt__GrepObjects"
    ]
  },
  "enabledPlugins": {
    "sap-abap@sap-skills": true,
    "ui5@claude-plugins-official": true,
    "sap-abap-cds@sap-skills": true,
    "sap-fiori-tools@sap-skills": true,
    "sapui5@sap-skills": true,
    "sapui5-cli@sap-skills": true,
    "sapui5-linter@sap-skills": true
  },
  "extraKnownMarketplaces": {
    "sap-skills": {
      "source": {
        "source": "git",
        "url": "git@github.com:secondsky/sap-skills.git"
      }
    }
  },
  "mcpServers": {
    "ui5": {
      "type": "stdio",
      "command": "ui5mcp",
      "args": [],
      "env": {
        "PATH": "/home/user/.node_modules_global/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/bin"
      }
    },
    "cap": {
      "type": "stdio",
      "command": "cds-mcp",
      "args": [],
      "env": {
        "PATH": "/home/user/.node_modules_global/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/bin"
      }
    },
    "fiori": {
      "type": "stdio",
      "command": "fiori-mcp",
      "args": [],
      "env": {
        "PATH": "/home/user/.node_modules_global/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/bin"
      }
    },
    "sap-docs-online-http": {
      "disabled": true,
      "timeout": 60,
      "type": "streamableHttp",
      "url": "https://sap-docs-mcp.cfapps.us10-001.hana.ondemand.com/mcp"
    },
    "abap-adt": {
      "type": "stdio",
      "command": "/home/user/vsp",
      "args": [],
      "env": {
        "SAP_URL": "https://vhmcads4ci.rise.melisap.com:44300",
        "SAP_USER": "EXT_JAIJARAM",
        "SAP_CLIENT": "200"
      }
    }
  }
}
